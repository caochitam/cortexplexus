# CortexPlexus Environment Variables
# Copy this file to .env and edit as needed.
# Most settings have sensible defaults — you can start with no changes.

# --- Embedding provider (default: Ollama offline, no API key needed) ---
# Uncomment and set your key ONLY if you want to use Google Gemini instead:
# EMBEDDING_PROVIDER=gemini
# GEMINI_API_KEY=your_gemini_api_key_here
# Get a free key at: https://aistudio.google.com/apikey

# --- Workspace mount (optional) ---
# If you want to index code that lives on this server, set the path here.
# It will be mounted read-only into the container at /workspace.
# Leave commented out if you only use the Local Agent (recommended).
# WORKSPACE_PATH=/path/to/your/code/workspace
