# CortexPlexus Environment Variables
# Copy this file to .env and fill in your values

# Google Gemini API Key (free: https://aistudio.google.com/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# Path to your code workspace (absolute path)
# This directory will be mounted read-only into the container
WORKSPACE_PATH=/path/to/your/code/workspace
